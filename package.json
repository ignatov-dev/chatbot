{
  "name": "xbo-chatbot",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175 --open --host",
    "build": "tsc -b && vite build",
    "preview": "pnpm run build && vite preview --port 5175 --open",
    "ingest": "node scripts/ingest.mjs -- questions.txt",
