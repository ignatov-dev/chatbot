    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dompurify": "^3.3.2",
    "dotenv": "^17.3.1",
    "framer-motion": "^12.34.3",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.577.0",
    "marked": "^17.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.13.1",
    "react-syntax-highlighter": "^16.1.0",
    "smartlook-client": "^10.0.0",
    "tailwind-merge": "^3.5.0",
